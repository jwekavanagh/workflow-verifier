{
  "$id": "https://workflow-verifier/schemas/cli-error-envelope.schema.json",
  "title": "ExecutionTruthLayerCliError",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "code",
    "message",
    "failureDiagnosis"
  ],
  "properties": {
    "schemaVersion": { "const": 2 },
    "kind": { "const": "execution_truth_layer_error" },
    "code": { "type": "string" },
    "message": { "type": "string", "maxLength": 2048 },
    "failureDiagnosis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "primaryOrigin", "confidence", "evidence", "actionableFailure"],
      "properties": {
        "summary": { "type": "string", "maxLength": 2048 },
        "primaryOrigin": {
          "$ref": "https://workflow-verifier/schemas/workflow-truth-report.schema.json#/$defs/failureOrigin"
        },
        "confidence": {
          "$ref": "https://workflow-verifier/schemas/workflow-truth-report.schema.json#/$defs/failureConfidence"
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["referenceCode"],
            "properties": {
              "referenceCode": { "type": "string" }
            }
          }
        },
        "actionableFailure": {
          "$ref": "https://workflow-verifier/schemas/workflow-truth-report.schema.json#/$defs/actionableFailure"
        }
      }
    }
  }
}
