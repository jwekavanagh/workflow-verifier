{
  "$id": "https://execution-truth-layer/schemas/tools-registry.schema.json",
  "title": "ToolsRegistry",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["toolId", "effectDescriptionTemplate", "verification"],
    "properties": {
      "toolId": { "type": "string", "minLength": 1 },
      "effectDescriptionTemplate": { "type": "string" },
      "verification": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "table", "key", "requiredFields"],
            "properties": {
              "kind": { "const": "sql_row" },
              "table": { "$ref": "#/$defs/tableSpec" },
              "key": { "$ref": "#/$defs/keySpec" },
              "requiredFields": { "$ref": "#/$defs/requiredFieldsPointer" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "effects"],
            "properties": {
              "kind": { "const": "sql_effects" },
              "effects": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["id", "table", "key", "requiredFields"],
                  "properties": {
                    "id": { "type": "string", "minLength": 1 },
                    "table": { "$ref": "#/$defs/tableSpec" },
                    "key": { "$ref": "#/$defs/keySpec" },
                    "requiredFields": { "$ref": "#/$defs/requiredFieldsPointer" }
                  }
                }
              }
            }
          }
        ]
      }
    }
  },
  "$defs": {
    "tableSpec": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["const"],
          "properties": { "const": { "type": "string", "minLength": 1 } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["pointer"],
          "properties": { "pointer": { "type": "string", "pattern": "^/" } }
        }
      ]
    },
    "keySpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["column", "value"],
      "properties": {
        "column": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["const"],
              "properties": { "const": { "type": "string", "minLength": 1 } }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["pointer"],
              "properties": { "pointer": { "type": "string", "pattern": "^/" } }
            }
          ]
        },
        "value": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["const"],
              "properties": {
                "const": { "type": ["string", "number", "boolean", "null"] }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["pointer"],
              "properties": { "pointer": { "type": "string", "pattern": "^/" } }
            }
          ]
        }
      }
    },
    "requiredFieldsPointer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pointer"],
      "properties": {
        "pointer": { "type": "string", "pattern": "^/" }
      }
    }
  }
}
