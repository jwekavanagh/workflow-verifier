{
  "$id": "https://execution-truth-layer/schemas/tools-registry.schema.json",
  "title": "ToolsRegistry",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["toolId", "effectDescriptionTemplate", "verification"],
    "properties": {
      "toolId": { "type": "string", "minLength": 1 },
      "effectDescriptionTemplate": { "type": "string" },
      "verification": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "table", "key", "requiredFields"],
        "properties": {
          "kind": { "const": "sql_row" },
          "table": {
            "oneOf": [
              { "type": "object", "additionalProperties": false, "required": ["const"], "properties": { "const": { "type": "string", "minLength": 1 } } },
              { "type": "object", "additionalProperties": false, "required": ["pointer"], "properties": { "pointer": { "type": "string", "pattern": "^/" } } }
            ]
          },
          "key": {
            "type": "object",
            "additionalProperties": false,
            "required": ["column", "value"],
            "properties": {
              "column": {
                "oneOf": [
                  { "type": "object", "additionalProperties": false, "required": ["const"], "properties": { "const": { "type": "string", "minLength": 1 } } },
                  { "type": "object", "additionalProperties": false, "required": ["pointer"], "properties": { "pointer": { "type": "string", "pattern": "^/" } } }
                ]
              },
              "value": {
                "oneOf": [
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["const"],
                    "properties": {
                      "const": { "type": ["string", "number", "boolean", "null"] }
                    }
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["pointer"],
                    "properties": { "pointer": { "type": "string", "pattern": "^/" } }
                  }
                ]
              }
            }
          },
          "requiredFields": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pointer"],
            "properties": {
              "pointer": { "type": "string", "pattern": "^/" }
            }
          }
        }
      }
    }
  }
}
