{
  "$id": "https://workflow-verifier/schemas/workflow-result.schema.json",
  "title": "WorkflowResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "workflowId",
    "status",
    "steps",
    "runLevelReasons",
    "verificationPolicy",
    "eventSequenceIntegrity",
    "verificationRunContext",
    "workflowTruthReport"
  ],
  "properties": {
    "schemaVersion": { "const": 15 },
    "workflowId": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["complete", "incomplete", "inconsistent"]
    },
    "runLevelReasons": {
      "type": "array",
      "items": {
        "$ref": "https://workflow-verifier/schemas/workflow-engine-result.schema.json#/$defs/reason"
      }
    },
    "verificationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["consistencyMode", "verificationWindowMs", "pollIntervalMs"],
      "properties": {
        "consistencyMode": { "type": "string", "enum": ["strong", "eventual"] },
        "verificationWindowMs": { "type": "integer", "minimum": 0 },
        "pollIntervalMs": { "type": "integer", "minimum": 0 }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "https://workflow-verifier/schemas/workflow-engine-result.schema.json#/$defs/step"
      }
    },
    "eventSequenceIntegrity": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": { "const": "normal" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "reasons"],
          "properties": {
            "kind": { "const": "irregular" },
            "reasons": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "https://workflow-verifier/schemas/workflow-engine-result.schema.json#/$defs/reason"
              }
            }
          }
        }
      ]
    },
    "verificationRunContext": {
      "$ref": "https://workflow-verifier/schemas/workflow-engine-result.schema.json#/$defs/verificationRunContext"
    },
    "workflowTruthReport": {
      "$ref": "https://workflow-verifier/schemas/workflow-truth-report.schema.json"
    }
  }
}
