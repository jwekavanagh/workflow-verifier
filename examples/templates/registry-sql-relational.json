[
  {
    "toolId": "example.sql_relational",
    "effectDescriptionTemplate": "Related line for order {/orderId} with sku {/sku}",
    "verification": {
      "kind": "sql_relational",
      "checks": [
        {
          "checkKind": "related_exists",
          "id": "lines_exist",
          "childTable": { "const": "order_lines" },
          "matchEq": [
            {
              "column": { "const": "order_id" },
              "value": { "pointer": "/orderId" }
            },
            {
              "column": { "const": "sku" },
              "value": { "pointer": "/sku" }
            }
          ]
        },
        {
          "checkKind": "aggregate",
          "id": "line_count",
          "table": { "const": "order_lines" },
          "fn": "COUNT_STAR",
          "whereEq": [
            {
              "column": { "const": "order_id" },
              "value": { "pointer": "/orderId" }
            }
          ],
          "expect": { "op": "eq", "value": { "const": 2 } }
        }
      ]
    }
  },
  {
    "toolId": "example.sql_relational_sum",
    "effectDescriptionTemplate": "Sum of amount for bucket {/bucket}",
    "verification": {
      "kind": "sql_relational",
      "checks": [
        {
          "checkKind": "aggregate",
          "id": "amount_sum",
          "table": { "const": "ledger_entries" },
          "fn": "SUM",
          "sumColumn": { "const": "amount" },
          "whereEq": [
            {
              "column": { "const": "bucket" },
              "value": { "pointer": "/bucket" }
            }
          ],
          "expect": { "op": "eq", "value": { "const": 0 } }
        }
      ]
    }
  }
]
