{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow-verifier.local/discovery-acquisition.schema.json",
  "title": "Discovery acquisition SSOT",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "slug",
    "visitorProblemAnswer",
    "heroTitle",
    "heroSubtitle",
    "homepageAcquisitionCtaLabel",
    "pageMetadata",
    "sections",
    "llms",
    "readmeFold",
    "readmeTitle",
    "homepageHero",
    "demandMoments",
    "cliFollowupLines"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "slug": { "type": "string", "const": "/database-truth-vs-traces" },
    "visitorProblemAnswer": {
      "type": "string",
      "minLength": 200,
      "allOf": [
        { "pattern": "[Rr]ead-?\\s*[Oo]nly" },
        { "pattern": "[Ss][Qq][Ll]" },
        { "pattern": "[Tt]race|[Tt]ool|[Ww]orkflow|[Aa]gent|[Ss]uccess\\s+flag" },
        { "pattern": "[Dd]atabase|[Rr]ow|[Pp]ersisted|[Ss]tate" },
        { "pattern": "[Ss]tructured.{0,80}[Tt]ool|[Tt]ool.{0,80}[Aa]ctivit" },
        { "pattern": "[Vv]erification\\s+time|[Aa]t\\s+verification" }
      ]
    },
    "heroTitle": { "type": "string", "minLength": 1 },
    "heroSubtitle": { "type": "string", "minLength": 1 },
    "homepageAcquisitionCtaLabel": { "type": "string", "minLength": 8 },
    "readmeTitle": {
      "type": "string",
      "minLength": 12,
      "pattern": "^[^#\\n]+$"
    },
    "homepageHero": {
      "type": "object",
      "additionalProperties": false,
      "required": ["what", "why", "when"],
      "properties": {
        "what": { "type": "string", "minLength": 40 },
        "why": { "type": "string", "minLength": 40 },
        "when": { "type": "string", "minLength": 40 }
      }
    },
    "demandMoments": {
      "type": "array",
      "minItems": 3,
      "maxItems": 12,
      "items": { "type": "string", "minLength": 12 }
    },
    "cliFollowupLines": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 220
      }
    },
    "pageMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["heading", "paragraphs"],
        "properties": {
          "heading": { "type": "string", "minLength": 1 },
          "paragraphs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "llms": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intentPhrases", "notFor", "relatedQueries"],
      "properties": {
        "intentPhrases": {
          "type": "array",
          "minItems": 5,
          "items": { "type": "string", "minLength": 1 }
        },
        "notFor": {
          "type": "array",
          "minItems": 3,
          "items": { "type": "string", "minLength": 1 }
        },
        "relatedQueries": {
          "type": "array",
          "minItems": 5,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "readmeFold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["templateLines"],
      "properties": {
        "templateLines": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 0 }
        }
      }
    }
  }
}
