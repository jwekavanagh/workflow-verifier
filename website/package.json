{
  "name": "agentskeptic-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "prebuild": "node ../scripts/generate-integrate-activation-shell.mjs && npm --prefix .. run sync:public-product-anchors && node ../scripts/sync-integrator-docs-embedded.mjs",
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "db:generate": "node ./scripts/drizzle-kit-guarded.mjs generate",
    "db:generate:telemetry": "node ./scripts/drizzle-kit-guarded.mjs generate --config drizzle.telemetry.config.ts",
    "db:migrate": "node ./scripts/db-migrate.mjs",
    "db:migrate:telemetry": "node ./scripts/db-migrate-telemetry.mjs",
    "test:vitest": "node ../scripts/sync-integrator-docs-embedded.mjs && vitest run"
  },
  "dependencies": {
    "@auth/core": "0.41.1",
    "@auth/drizzle-adapter": "1.11.1",
    "@vercel/analytics": "^2.0.1",
    "agentskeptic": "0.1.9",
    "drizzle-orm": "0.45.2",
    "next": "^16.2.3",
    "next-auth": "^5.0.0-beta.25",
    "nodemailer": "8.0.5",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^4.0.1",
    "stripe": "^17.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "6.4.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cheerio": "^1.0.0",
    "drizzle-kit": "0.31.10",
    "jsdom": "^26.1.0",
    "tar": "7.5.13",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4",
    "yaml": "2.8.3"
  }
}
