# Local: no sslmode (localhost is not auto-upgraded). Hosted Supabase / Vercel: sslmode=require on DATABASE_URL
# (app: ensureSslModeRequire). drizzle-kit migrate uses node-pg — drizzle.config adds uselibpqcompat=true for non-localhost URLs.
# Example Supabase: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/wfv_commercial
# Required for `next build`, production, and CI. Optional for local `npm run dev` (insecure fallback + console warning).
AUTH_SECRET=generate_a_long_random_string_at_least_32_chars
NEXTAUTH_SECRET=${AUTH_SECRET}
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
# Bare email only (required for next dev / next build). Regex after trim: /^[^\s@]+@[^\s@]+\.[^\s@]+$/
CONTACT_SALES_EMAIL=kavanagh.james@ymail.com
# Resend: production must use EMAIL_FROM on a domain you verify at https://resend.com/domains
# Using onboarding@resend.dev only works for development: Resend then accepts recipients that match
# the mailbox tied to your Resend account (other addresses return 403). Fix by verifying DNS and
# setting EMAIL_FROM to e.g. "AgentSkeptic <auth@your-verified-domain.com>".
EMAIL_FROM="AgentSkeptic <onboarding@resend.dev>"
RESEND_API_KEY=re_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# One price id per plan, or several (comma/space) so legacy Stripe prices still map after you rotate the default (first id is used for new Checkout).
STRIPE_PRICE_INDIVIDUAL=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_PRICE_BUSINESS=price_...
# E2E only — never in production:
# E2E_COMMERCIAL_FUNNEL=1
# RESERVE_EMERGENCY_ALLOW=1
